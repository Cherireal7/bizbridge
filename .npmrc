auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-workspace-packages=true
link-workspace-packages=true
# pnpm v10+ treats ignored build scripts as fatal by default. Our
# onlyBuiltDependencies list already opts-in the ones we need; this
# flips the enforcement back to non-fatal for anything else.
strict-dep-builds=false
