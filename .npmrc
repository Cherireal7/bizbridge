auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-workspace-packages=true
link-workspace-packages=true
# pnpm v10+ treats ignored build scripts as fatal by default. Our
# onlyBuiltDependencies list already opts-in the ones we need; this
# flips the enforcement back to non-fatal for anything else.
strict-dep-builds=false
# pnpm v11 auto-runs `pnpm install` before every script to verify deps state.
# On Vercel that inner install re-triggers the ignored-builds fatal error even
# with our config flags. Turn the check off — Vercel already installs before
# build, so we don't need the runtime re-verification.
verify-deps-before-run=false
