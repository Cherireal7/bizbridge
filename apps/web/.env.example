# --- Required in production ---
# Fully-qualified URL where the app is served. Used by sitemap.xml, robots.txt,
# JSON-LD, Better Auth trusted origins, and every canonical/og link.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Neon (or any Postgres). Used by both Payload and Better Auth.
DATABASE_URL=postgres://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/bizbridge?sslmode=require

# Payload admin session encryption. `openssl rand -hex 32`.
PAYLOAD_SECRET=replace-me-with-openssl-rand-hex-32

# Better Auth signing key. `openssl rand -hex 32`.
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# --- Consult / contact (public defaults live in src/lib/flags.ts) ---
NEXT_PUBLIC_CONSULT_EMAIL=cheridemeke777@gmail.com
NEXT_PUBLIC_CONSULT_TELEGRAM=https://t.me/Cherireal7
NEXT_PUBLIC_CONSULT_FORMSUBMIT=

# --- Optional: OAuth providers (leave empty to disable) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
