# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Feature flags ---
# Accounts (login, signup, dashboard, pricing, checkout) are hidden by default.
# Set to "true" to re-enable when the paid tier is ready to launch.
NEXT_PUBLIC_ENABLE_ACCOUNTS=false

# --- Consult / contact ---
# Where the /consult form and CTAs route to. Formsubmit needs a one-time
# activation click on the first form submission. Empty values fall back to the
# hard-coded defaults in apps/web/src/lib/flags.ts.
NEXT_PUBLIC_CONSULT_EMAIL=cheridemeke7@gmail.com
NEXT_PUBLIC_CONSULT_TELEGRAM=https://t.me/Cherireal7
NEXT_PUBLIC_CONSULT_FORMSUBMIT=

# --- Database (shared with apps/api) ---
DATABASE_URL=postgres://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/bizbridge?sslmode=require

# --- Payload CMS ---
PAYLOAD_SECRET=replace-me-with-openssl-rand-hex-32

# --- Better Auth ---
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudflare R2 (used by Payload @payloadcms/storage-s3) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bizbridge-media
R2_PUBLIC_URL=https://media.example.com
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
