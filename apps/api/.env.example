# apps/api is optional — Better Auth now lives in Next.js. This service is
# only needed if you want the Fastify data endpoints (sectors, reports,
# experts, bookings, calculator, checklists) as a separate host, e.g. for a
# mobile client.

PORT=4000
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# Shared with apps/web.
DATABASE_URL=postgres://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/bizbridge?sslmode=require
