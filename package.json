{
  "name": "bizbridge-ethiopia",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "dev:web": "pnpm --filter @bizbridge/web dev",
    "dev:api": "pnpm --filter @bizbridge/api dev",
    "build": "pnpm -r --no-bail build",
    "lint": "pnpm -r --no-bail lint",
    "typecheck": "pnpm -r --no-bail typecheck",
    "test": "pnpm -r --no-bail test",
    "clean": "pnpm -r --no-bail clean && rimraf node_modules",
    "db:generate": "pnpm --filter @bizbridge/api db:generate",
    "db:migrate": "pnpm --filter @bizbridge/api db:migrate",
    "db:studio": "pnpm --filter @bizbridge/api db:studio",
    "db:seed": "pnpm --filter @bizbridge/api db:seed",
    "payload:generate-types": "pnpm --filter @bizbridge/web payload generate:types",
    "payload:migrate": "pnpm --filter @bizbridge/web payload migrate",
    "seed:mor": "pnpm --filter @bizbridge/web seed:mor"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "prettier": "^3.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "turbo",
      "unrs-resolver"
    ]
  }
}
